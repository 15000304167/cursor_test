# Profile: mcp_replay | sim | hardware
TEST_PROFILE=mcp_replay

# MCP HTTP base (no trailing /mcp if using default below)
DIMOS_MCP_URL=http://127.0.0.1:9990
DIMOS_MCP_PATH=/mcp

# When true, integration tests skip starting dimos (assume stack already up)
DIMOS_SKIP_STACK=0

# Skip integration if dimos CLI missing (CI without DimOS)
DIMOS_REQUIRE_CLI=0

# Real robot
ROBOT_IP=192.168.123.161

# Must be set exactly for hardware tests
# HARDWARE_TEST_ACK=I_UNDERSTAND

# Artifacts root (default: ./artifacts)
TEST_ARTIFACTS_DIR=

# Git / build metadata (optional, set in CI)
GIT_SHA=
